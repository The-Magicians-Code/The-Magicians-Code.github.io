---
// musicplayer — the liquid-glass module showcased as a player bar. Ported 1:1
// from the old prod nav pill (#nav-pill geometry + glass treatment + the module
// defaults, which is exactly what made the refraction work in production), with
// the nav text-buttons dropped. A scrollable sample music library sits behind it
// so the glass refracts live content as you scroll — the Apple-Music feel.
import { Icon } from 'astro-icon/components';
import '../styles/liquid-glass.css';

const library = [
  { title: 'Liquid Motion', artist: 'The Magicians Code' },
  { title: 'Refraction', artist: 'Nova Atlas' },
  { title: 'Glass Houses', artist: 'Marlowe Vance' },
  { title: 'Specular', artist: 'Ivo Kessler' },
  { title: 'Snell’s Law', artist: 'The Bezels' },
  { title: 'Backdrop', artist: 'Cassia Vale' },
  { title: 'Displacement Map', artist: 'Orla Finch' },
  { title: 'Index of Refraction', artist: 'Hale & Crane' },
  { title: 'Frosted', artist: 'Lune' },
  { title: 'Caustics', artist: 'Theo Marsh' },
  { title: 'Total Internal', artist: 'Sable Wren' },
  { title: 'Rim Light', artist: 'Juniper Ash' },
  { title: 'Aperture', artist: 'The Meridian' },
  { title: 'Chromatic', artist: 'Dorian Frost' },
  { title: 'Parallax', artist: 'Vesper Lane' },
  { title: 'Saturate', artist: 'Kit Halloran' },
  { title: 'Inner Glow', artist: 'Mara Quill' },
  { title: 'Tilt Shift', artist: 'August Reyes' },
  { title: 'Soft Edges', artist: 'Linnea Cole' },
  { title: 'Highlight', artist: 'The Atlas Pup' },
  { title: 'Translucent', artist: 'Wren & Oak' },
  { title: 'Bevel', artist: 'Cyan Mercer' },
  { title: 'Dispersion', artist: 'Nori Vale' },
  { title: 'Light Path', artist: 'Halcyon Drift' },
  { title: 'Ambient Occlusion', artist: 'Esme Lark' },
  { title: 'Bloom', artist: 'The Quiet Lens' },
  { title: 'Reflectance', artist: 'Otis Vane' },
  { title: 'Falloff', artist: 'Petra Sol' },
  { title: 'Roughness', artist: 'Calder Ng' },
  { title: 'Sheen', artist: 'The Magicians Code' },
];
const cover = (i: number) => `oklch(70% 0.2 ${(i * 47) % 360})`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>musicplayer — liquid glass</title>

    <script is:inline>
      // Same UA sniff as BaseLayout: engines that don't render url(#filter) in
      // backdrop-filter (Safari, Firefox) get the frosted-glass fallback class
      // pre-paint, so the runtime skips them cleanly (no FOUC).
      (function () {
        try {
          var ua = navigator.userAgent;
          var noSvg = (/AppleWebKit/.test(ua) && !/Chrome|Chromium|Edg/.test(ua)) || /Firefox/.test(ua);
          if (noSvg) document.documentElement.classList.add('lg-no-svg-backdrop');
        } catch (_) {}
      })();
    </script>
  </head>

  <body>
    <!-- Scrollable library — the live backdrop the glass refracts. -->
    <main class="library">
      <h1 class="lib-title">Library</h1>
      <ul class="tracks">
        {library.map((t, i) => (
          <li class="track">
            <span class="t-art" style={`--c: ${cover(i)}`}></span>
            <span class="t-meta">
              <span class="t-title">{t.title}</span>
              <span class="t-artist">{t.artist}</span>
            </span>
            <span class="t-dur">{`${2 + (i % 3)}:${String((i * 17) % 60).padStart(2, '0')}`}</span>
          </li>
        ))}
      </ul>
    </main>

    <!-- The glass player bar — prod nav pill, 1:1, text-buttons dropped. -->
    <div class="player-dock">
      <div id="player-pill" class="liquid-glass">
        <span class="np-art" style="--c: oklch(72% 0.2 18)"></span>
        <span class="np-meta">
          <span class="np-title">Liquid Motion</span>
          <span class="np-artist">The Magicians Code</span>
        </span>

        <div class="np-controls">
          <button class="np-ctl" type="button" aria-label="Previous"><Icon name="lucide:skip-back" /></button>
          <button class="np-ctl np-play" id="play" type="button" aria-label="Play" aria-pressed="false">
            <Icon name="lucide:play" class="i-play" />
            <Icon name="lucide:pause" class="i-pause" />
          </button>
          <button class="np-ctl" type="button" aria-label="Next"><Icon name="lucide:skip-forward" /></button>
        </div>
      </div>
    </div>

    <script>
      import '../scripts/liquid-glass';
      const play = document.getElementById('play');
      play?.addEventListener('click', () => {
        const on = play.classList.toggle('is-playing');
        play.setAttribute('aria-pressed', String(on));
        play.setAttribute('aria-label', on ? 'Pause' : 'Play');
      });
    </script>

    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0a0a0d;
        --ink: #f0f0f5;
        --ink-dim: #a0a0aa;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; }
      body { background: var(--bg); color: var(--ink); }

      /* ── Scrollable library ─────────────────────────────────────────────── */
      .library {
        max-width: 760px;
        margin: 0 auto;
        padding: 28px 20px 160px; /* bottom room so the last rows clear the dock */
      }
      .lib-title { font-size: clamp(28px, 6vw, 44px); font-weight: 800; letter-spacing: -0.02em; margin: 24px 4px 18px; }
      .tracks { list-style: none; margin: 0; padding: 0; }
      .track {
        display: flex; align-items: center; gap: 14px;
        padding: 10px 8px;
        border-radius: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .track:first-child { border-top: 0; }
      .track:hover { background: rgba(255, 255, 255, 0.04); }
      .t-art {
        flex: none; width: 48px; height: 48px; border-radius: 8px;
        background:
          radial-gradient(120% 120% at 30% 25%, color-mix(in oklab, var(--c) 85%, white) 0%, var(--c) 55%, color-mix(in oklab, var(--c) 70%, black) 100%);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
      }
      .t-meta { flex: 1; min-width: 0; display: flex; flex-direction: column; }
      .t-title { font-size: 15px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .t-artist { font-size: 13px; color: var(--ink-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .t-dur { flex: none; font-size: 13px; color: var(--ink-dim); font-variant-numeric: tabular-nums; }

      /* ── The dock + glass pill (ported 1:1 from the prod #nav-pill) ──────── */
      .player-dock {
        position: fixed;
        left: 0; right: 0;
        bottom: max(20px, env(safe-area-inset-bottom, 0px));
        z-index: 20;
        display: flex;
        justify-content: center;
        padding: 0 20px;
        pointer-events: none;
      }
      .player-dock > * { pointer-events: auto; }

      /* #nav-pill geometry/treatment, verbatim from global.css (the exact glass
         the prod pill had — defaults, no per-instance --lg override). */
      #player-pill {
        position: relative;
        isolation: isolate;
        width: min(896px, 100%);
        height: 64px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0 0.75rem 0 1rem;
        border-radius: 999px;
        color: var(--ink);
        background: rgba(255, 255, 255, 0.06);
        box-shadow:
          inset 0 0 12px -3px rgba(255, 255, 255, 0.30),
          0 18px 30px -10px rgba(0, 0, 0, 0.55);
        -webkit-user-select: none;
        user-select: none;
      }
      #player-pill::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0.03) 40%, transparent 70%);
        pointer-events: none;
        z-index: -1;
      }
      /* Safari/Firefox fallback (no SVG-in-backdrop): plain frosted glass. */
      html.lg-no-svg-backdrop #player-pill {
        -webkit-backdrop-filter: blur(18px) saturate(140%);
        backdrop-filter: blur(18px) saturate(140%);
      }
      html.lg-no-svg-backdrop #player-pill::before { display: none; }

      /* Below 641px the runtime skips the pill (the prod glass was desktop-only),
         so it would show the heavy .liquid-glass blur(18px). Give it a lighter
         frosted fallback here — also avoids the costly SVG re-raster while the
         library scrolls under it on phones. */
      @media (max-width: 640px) {
        #player-pill {
          -webkit-backdrop-filter: blur(12px) saturate(1.2);
          backdrop-filter: blur(12px) saturate(1.2);
        }
      }

      .np-art {
        flex: none; width: 44px; height: 44px; border-radius: 10px;
        background:
          radial-gradient(120% 120% at 30% 25%, color-mix(in oklab, var(--c) 85%, white) 0%, var(--c) 55%, color-mix(in oklab, var(--c) 70%, black) 100%);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
      }
      .np-meta { flex: 1; min-width: 0; display: flex; flex-direction: column; }
      .np-title { font-size: 14px; font-weight: 650; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .np-artist { font-size: 12px; color: var(--ink-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

      .np-controls { flex: none; display: flex; align-items: center; gap: 2px; }
      .np-ctl {
        display: inline-grid; place-items: center;
        width: 40px; height: 40px;
        border: 0; border-radius: 999px; background: transparent;
        color: var(--ink); cursor: pointer;
        transition: background-color 0.15s ease, transform 0.12s ease;
      }
      .np-ctl:hover { background: rgba(255, 255, 255, 0.12); }
      .np-ctl:active { transform: scale(0.94); }
      .np-ctl svg { width: 20px; height: 20px; }
      .np-play svg { width: 24px; height: 24px; }
      .np-play .i-pause { display: none; }
      .np-play.is-playing .i-play { display: none; }
      .np-play.is-playing .i-pause { display: inline; }

      @media (max-width: 520px) {
        #player-pill { height: 60px; }
        .np-art { width: 40px; height: 40px; }
      }
    </style>
  </body>
</html>
