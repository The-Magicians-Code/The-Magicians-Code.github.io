---
// musicplayer — a standalone showcase for the liquid-glass module, repurposed
// from the old nav pill into an Apple-Music-iOS-style "Now Playing" player bar.
// Deliberately renders its own <html> (not BaseLayout) so it's an isolated demo
// with full control over the backdrop the glass refracts.
import { Icon } from 'astro-icon/components';
import '../styles/liquid-glass.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>musicplayer — liquid glass</title>

    <script is:inline>
      // Same UA sniff as BaseLayout: engines that don't render url(#filter) in
      // backdrop-filter (Safari, Firefox) get the frosted-glass fallback class
      // pre-paint, so the runtime skips them cleanly (no FOUC).
      (function () {
        try {
          var ua = navigator.userAgent;
          var noSvg = (/AppleWebKit/.test(ua) && !/Chrome|Chromium|Edg/.test(ua)) || /Firefox/.test(ua);
          if (noSvg) document.documentElement.classList.add('lg-no-svg-backdrop');
        } catch (_) {}
      })();
    </script>
  </head>

  <body>
    <main class="stage" aria-label="Now playing">
      <!-- Backdrop the glass refracts: the blurred "album art" wallpaper. -->
      <div class="wall" aria-hidden="true"></div>

      <section class="nowplaying">
        <div class="cover" role="img" aria-label="Album artwork"></div>
        <h1 class="np-title">Liquid Motion</h1>
        <p class="np-artist">The Magicians Code</p>
      </section>

      <!-- The player bar — this is the liquid-glass surface. -->
      <div
        id="player"
        class="player liquid-glass"
        style="--lg-thickness: 70; --lg-bezel: 16; --lg-ior: 1.5; --lg-blur: 6; --lg-saturate: 130; --lg-svg-saturate: 3.5; --lg-spec-alpha: 0.45;"
      >
        <div class="art" role="img" aria-label="Album artwork"></div>

        <div class="meta">
          <div class="title">Liquid Motion</div>
          <div class="artist">The Magicians Code</div>
        </div>

        <div class="controls">
          <button class="ctl" type="button" aria-label="Previous">
            <Icon name="lucide:skip-back" />
          </button>
          <button class="ctl play" id="play" type="button" aria-label="Play" aria-pressed="false">
            <Icon name="lucide:play" class="i-play" />
            <Icon name="lucide:pause" class="i-pause" />
          </button>
          <button class="ctl" type="button" aria-label="Next">
            <Icon name="lucide:skip-forward" />
          </button>
        </div>

        <div class="scrubber" aria-hidden="true">
          <div class="scrubber-fill" id="fill"></div>
        </div>
      </div>
    </main>

    <script>
      import '../scripts/liquid-glass';

      // Tiny demo behaviour: play/pause toggle + a fake progress drift.
      const play = document.getElementById('play');
      const fill = document.getElementById('fill');
      let playing = false;
      let progress = 0.28;
      let raf = 0;
      let last = 0;

      const render = () => {
        if (fill) fill.style.width = (progress * 100).toFixed(2) + '%';
      };
      render();

      const loop = (t: number) => {
        if (last) progress = Math.min(1, progress + (t - last) / 180000); // ~3 min track
        last = t;
        render();
        if (progress >= 1) { progress = 0; }
        if (playing) raf = requestAnimationFrame(loop);
      };

      play?.addEventListener('click', () => {
        playing = !playing;
        play.classList.toggle('is-playing', playing);
        play.setAttribute('aria-pressed', String(playing));
        play.setAttribute('aria-label', playing ? 'Pause' : 'Play');
        if (playing) { last = 0; raf = requestAnimationFrame(loop); }
        else { cancelAnimationFrame(raf); }
      });
    </script>

    <style is:global>
      :root {
        color-scheme: dark;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; }

      .stage {
        position: relative;
        min-height: 100svh;
        overflow: hidden;
        display: grid;
        place-items: center;
        background: #0b0b12;
        color: #f4f4f7;
      }

      /* Vibrant "album art" wallpaper — gives the glass something rich to bend. */
      .wall {
        position: absolute;
        inset: -10%;
        background:
          radial-gradient(40% 50% at 22% 28%, oklch(70% 0.22 18) 0%, transparent 60%),
          radial-gradient(45% 55% at 80% 22%, oklch(72% 0.2 305) 0%, transparent 62%),
          radial-gradient(50% 60% at 70% 82%, oklch(74% 0.19 230) 0%, transparent 60%),
          radial-gradient(45% 55% at 18% 80%, oklch(76% 0.2 145) 0%, transparent 60%),
          #0b0b12;
        filter: saturate(1.1);
      }

      .nowplaying {
        position: relative;
        text-align: center;
        transform: translateY(-6vh);
        z-index: 1;
      }
      .cover {
        width: min(46vw, 300px);
        aspect-ratio: 1;
        margin: 0 auto 28px;
        border-radius: 24px;
        background:
          conic-gradient(from 210deg at 50% 50%,
            oklch(72% 0.2 18), oklch(74% 0.18 305), oklch(76% 0.18 230),
            oklch(78% 0.18 145), oklch(72% 0.2 18));
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
      }
      .np-title { margin: 0; font-size: clamp(22px, 4vw, 34px); font-weight: 700; letter-spacing: -0.01em; }
      .np-artist { margin: 6px 0 0; font-size: 15px; opacity: 0.7; }

      /* ── The glass player bar ───────────────────────────────────────────── */
      .player {
        position: fixed;
        left: 50%;
        bottom: max(24px, env(safe-area-inset-bottom, 0px));
        transform: translateX(-50%);
        z-index: 5;
        width: min(560px, calc(100vw - 28px));
        height: 76px;
        padding: 0 14px 0 14px;
        border-radius: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: #fff;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.4);
        /* subtle inner tint + rim so it reads as glass even before/without the
           SVG refraction (fallback engines) */
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.16);
        -webkit-user-select: none;
        user-select: none;
      }

      .player .art {
        flex: none;
        width: 52px;
        height: 52px;
        border-radius: 12px;
        background:
          conic-gradient(from 210deg at 50% 50%,
            oklch(72% 0.2 18), oklch(74% 0.18 305), oklch(76% 0.18 230),
            oklch(78% 0.18 145), oklch(72% 0.2 18));
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), inset 0 0 0 1px rgba(255,255,255,0.12);
      }

      .player .meta { min-width: 0; flex: 1; }
      .player .title {
        font-size: 15px; font-weight: 650; line-height: 1.2;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .player .artist {
        font-size: 13px; line-height: 1.2; opacity: 0.72;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }

      .player .controls { flex: none; display: flex; align-items: center; gap: 4px; }
      .player .ctl {
        display: inline-grid;
        place-items: center;
        width: 40px; height: 40px;
        border: 0; border-radius: 999px;
        background: transparent;
        color: #fff;
        cursor: pointer;
        transition: background-color 0.15s ease, transform 0.12s ease;
      }
      .player .ctl:hover { background: rgba(255, 255, 255, 0.14); }
      .player .ctl:active { transform: scale(0.94); }
      .player .ctl svg { width: 20px; height: 20px; }
      .player .ctl.play svg { width: 24px; height: 24px; }
      .player .ctl.play { width: 44px; height: 44px; }

      /* play/pause icon crossfade */
      .player .ctl.play .i-pause { display: none; }
      .player .ctl.play.is-playing .i-play { display: none; }
      .player .ctl.play.is-playing .i-pause { display: inline; }

      .player .scrubber {
        position: absolute;
        left: 14px; right: 14px; bottom: 8px;
        height: 3px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.22);
        overflow: hidden;
      }
      .player .scrubber-fill {
        height: 100%;
        width: 28%;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.9);
      }

      @media (max-width: 480px) {
        .player { height: 70px; }
        .player .art { width: 46px; height: 46px; }
      }
    </style>
  </body>
</html>
