---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResumeModeToggle from '../components/ResumeModeToggle.astro';
import ResumeMap from '../components/ResumeMap.astro';
import { resume } from '../data/resume';
---

<BaseLayout
  title={`Resume — ${resume.name}`}
  description={`The ${resume.title.toLowerCase()} resume of ${resume.name}.`}
  canonicalPath="/resume/"
  robots="noindex, nofollow"
>
  <Fragment slot="head">
    <meta name="googlebot" content="noindex, nofollow" />
  </Fragment>

  <main class="resume is-interactive" data-resume-scope>
    <header class="resume-toolbar">
      <ResumeModeToggle defaultMode="interactive" />
      <a
        href="/Tanel_Treuberg_Software_Engineer.pdf"
        target="_blank"
        rel="noopener"
        class="resume-print-btn"
        aria-label="Open resume PDF in a new tab"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 3h6v6" />
          <path d="M10 14 21 3" />
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
        </svg>
        <span>View PDF</span>
      </a>
    </header>

    <header class="resume-header">
      <h1>{resume.name}</h1>
      <p class="resume-title">{resume.title}</p>
      <p class="resume-where">{resume.baseLocation.city}, {resume.baseLocation.country}</p>
      <ul class="resume-contact">
        {resume.contact.map((c) => (
          <li>
            <a
              href={c.href}
              target={c.href.startsWith('http') ? '_blank' : undefined}
              rel={c.href.startsWith('http') ? 'noopener' : undefined}
            >
              <span class="contact-screen">{c.label}</span>
              {c.printLabel && <span class="contact-print">{c.printLabel}</span>}
            </a>
          </li>
        ))}
      </ul>
    </header>

    <section class="resume-section">
      <h2>Summary</h2>
      <p class="resume-summary">{resume.summary}</p>
    </section>

    <section class="resume-section">
      <h2>Experience</h2>
      <div class="resume-entries">
        {resume.experience.map((job) => (
          <article class="resume-entry">
            <button
              type="button"
              class="resume-entry-header"
              aria-expanded="false"
              data-resume-entry-trigger
            >
              <div class="entry-titles">
                <h3>{job.role}</h3>
                <p class="entry-company">
                  <span>{job.company}</span>
                  <span class="entry-dot">·</span>
                  <span>{job.location.city}, {job.location.country}</span>
                </p>
              </div>
              <span class="entry-dates">{job.dates.display}</span>
              <svg
                class="entry-chevron"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </button>
            {job.tagline && <p class="entry-tagline">{job.tagline}</p>}
            <div class="entry-body" data-resume-entry-body>
              <div class="entry-body-inner">
                <div class="entry-map-slot">
                  <ResumeMap city={job.location.city} country={job.location.country} />
                </div>
                <ul class="entry-bullets">
                  {job.bullets.map((b) => <li>{b}</li>)}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="resume-section">
      <h2>Education</h2>
      <div class="resume-entries">
        {resume.education.map((edu) => (
          <article class="resume-entry resume-entry--open">
            <div class="resume-entry-header resume-entry-header--static">
              <div class="entry-titles">
                <h3>{edu.degree}</h3>
                <p class="entry-company">
                  <span>{edu.institution}</span>
                  <span class="entry-dot">·</span>
                  <span>{edu.location.city}, {edu.location.country}</span>
                </p>
              </div>
              <span class="entry-dates">{edu.dates.display}</span>
            </div>
            {edu.notes && (
              <ul class="entry-bullets entry-bullets--education">
                {edu.notes.map((n) => <li>{n}</li>)}
              </ul>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="resume-section">
      <h2>Skills</h2>
      <dl class="resume-skills">
        {resume.skills.map((group) => (
          <div class="skill-row">
            <dt>{group.label}</dt>
            <dd>{group.items.join(' · ')}</dd>
          </div>
        ))}
      </dl>
    </section>

    {resume.interests && (
      <section class="resume-section">
        <h2>Interests</h2>
        <p class="resume-interests">{resume.interests}</p>
      </section>
    )}

    <footer class="resume-foot">
      Last updated · {resume.meta.updatedAt}
    </footer>
  </main>
</BaseLayout>

<script>
  // ── Entry expand/collapse (Interactive mode only) ──
  document.querySelectorAll<HTMLButtonElement>('[data-resume-entry-trigger]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const entry = btn.closest<HTMLElement>('.resume-entry');
      if (!entry) return;
      const open = entry.classList.toggle('resume-entry--open');
      btn.setAttribute('aria-expanded', String(open));
    });
  });
</script>

<style>
  /* ============================================================
     RESUME — shared base
     ============================================================ */
  .resume {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 24px 80px;
    font-family: var(--font-sans);
    color: var(--ink);
  }

  .resume-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .resume-print-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 999px;
    background: var(--ink);
    color: var(--bg);
    border: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .resume-print-btn:hover {
    box-shadow: 0 8px 24px -10px var(--ink);
  }
  .resume-print-btn:active {
    transform: scale(0.97);
  }
  .resume-print-btn svg { width: 12px; height: 12px; }

  /* ── Header ── */
  .resume-header { margin-bottom: 24px; }
  .resume-header h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2rem, 1.5vw + 1.5rem, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .resume-title {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--accent);
    font-size: 1.125rem;
    margin: 4px 0 0;
  }
  .resume-where {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    margin: 14px 0 0;
  }
  .resume-contact {
    list-style: none;
    padding: 0;
    margin: 8px 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .resume-contact a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    transition: color 200ms, border-color 200ms;
  }
  .resume-contact a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .contact-print { display: none; }

  /* ── Sections ── */
  .resume-section { margin-bottom: 40px; }
  .resume-section h2 {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule);
  }
  .resume-summary {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--ink);
    margin: 0;
    text-wrap: pretty;
  }

  /* ── Entries (experience + education) ── */
  .resume-entries {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .resume-entry { display: flex; flex-direction: column; }
  .resume-entry-header {
    width: 100%;
    background: none;
    border: 0;
    padding: 0;
    color: inherit;
    text-align: left;
    cursor: pointer;
    display: grid;
    grid-template-columns: 1fr auto auto;
    column-gap: 16px;
    align-items: baseline;
    font: inherit;
  }
  .resume-entry-header--static {
    cursor: default;
    grid-template-columns: 1fr auto;
  }
  .entry-titles h3 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.125rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--ink);
  }
  .entry-company {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-3);
    margin: 4px 0 0;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    align-items: center;
  }
  .entry-dot { opacity: 0.5; }
  .entry-dates {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .entry-chevron {
    width: 16px;
    height: 16px;
    color: var(--ink-3);
    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
    flex-shrink: 0;
  }
  .resume-entry--open .entry-chevron { transform: rotate(180deg); }
  .resume-entry-header:hover .entry-chevron { color: var(--accent); }
  .resume-entry-header:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  .entry-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--ink-dim);
    margin: 10px 0 0;
  }

  /* ── Entry body collapse mechanic ──
     Default: expanded (1fr) so formal/print stays open without JS.
     Interactive mode + not open: collapsed (0fr). */
  .entry-body {
    display: grid;
    grid-template-rows: 1fr;
    transition:
      grid-template-rows 320ms cubic-bezier(0.22, 1, 0.36, 1),
      padding 320ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 240ms cubic-bezier(0.22, 1, 0.36, 1);
    padding-top: 14px;
  }
  .entry-body > * { min-height: 0; overflow: hidden; }
  .entry-body-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    align-items: start;
  }
  .entry-map-slot { display: none; } /* shown only in Interactive mode */
  .entry-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .entry-bullets li {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--ink);
    padding-left: 16px;
    position: relative;
    text-wrap: pretty;
  }
  .entry-bullets li::before {
    content: '';
    position: absolute;
    left: 2px;
    top: 0.65em;
    width: 6px;
    height: 1px;
    background: var(--accent);
  }
  .entry-bullets--education li { padding-left: 0; }
  .entry-bullets--education li::before { display: none; }
  .entry-bullets--education {
    margin-top: 14px;
    gap: 8px;
  }

  /* ── Skills ── */
  .resume-skills {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin: 0;
  }
  .skill-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 16px;
    align-items: baseline;
  }
  .skill-row dt {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .skill-row dd {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
  }
  @media (max-width: 560px) {
    .skill-row { grid-template-columns: 1fr; gap: 4px; }
  }

  .resume-interests {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
  }

  .resume-foot {
    margin-top: 64px;
    padding-top: 16px;
    border-top: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }

  /* ============================================================
     INTERACTIVE MODE  (default)
     ============================================================ */
  .resume.is-interactive .entry-map-slot { display: block; }
  .resume.is-interactive .resume-entry:not(.resume-entry--open) .entry-body {
    grid-template-rows: 0fr;
    padding-top: 0;
    opacity: 0;
  }

  /* ============================================================
     FORMAL MODE  (toggle right pill)
     ============================================================ */
  .resume.is-formal .entry-chevron { display: none; }
  .resume.is-formal .resume-entry-header { cursor: default; }
  .resume.is-formal .entry-tagline { display: none; }
  .resume.is-formal .entry-map-slot { display: none; }
  .resume.is-formal .resume-entry .entry-body {
    grid-template-rows: 1fr;
    padding-top: 14px;
    opacity: 1;
  }

  /* ============================================================
     PRINT  — force Formal layout regardless of toggle state
     ============================================================ */
  @media print {
    /* Hide site chrome and animated layers */
    :global(#site-nav),
    :global(#mobile-menu),
    :global(.nav-progressive-blur),
    :global(.nav-tuner),
    :global(.site-footer),
    :global(body)::before {
      display: none !important;
    }
    /* Reset the layout's top padding (was pt-28 on body) */
    :global(body) {
      padding-top: 0 !important;
      background: white !important;
    }
    /* Force light tokens so dark-mode visitors get clean print output. */
    :global(html.dark),
    :global(html) {
      --bg: #ffffff !important;
      --paper: #ffffff !important;
      --ink: #1a1a1c !important;
      --ink-dim: #4d4d52 !important;
      --ink-3: #8e8a82 !important;
      --rule: rgba(26, 26, 28, 0.18) !important;
      --accent: #b34a2f !important;
    }
    /* Disable any section-fade-in opacity:0 starts */
    :global(.section-fade-in) {
      opacity: 1 !important;
      animation: none !important;
    }

    @page {
      size: A4;
      /* Asymmetric: visible top margin, tight bottom so the whole resume
         fits on a single A4 page in Safari (which prints ~3% looser than
         Chrome on vertical rhythm). Horizontal stays at 10mm. */
      margin: 12mm 10mm 7mm 10mm;
    }

    .resume {
      max-width: none;
      padding: 0;
      color: var(--ink);
    }
    .resume-toolbar { display: none; }

    /* Force formal presentation regardless of class on .resume */
    .resume .entry-chevron,
    .resume .entry-tagline,
    .resume .entry-map-slot { display: none !important; }
    .resume .resume-entry-header { cursor: default; }
    .resume .entry-body {
      grid-template-rows: 1fr !important;
      padding-top: 10px !important;
      opacity: 1 !important;
      transition: none !important;
    }
    .resume .entry-body > * { overflow: visible; }
    .resume .entry-body-inner {
      display: block;
    }

    /* Print typography: slightly tighter, A4-friendly. */
    .resume-header { margin-bottom: 6pt; }
    .resume-header h1 { font-size: 18pt; }
    .resume-title { font-size: 10.5pt; margin-top: 1pt; }
    .resume-where { margin-top: 4pt; color: var(--ink-dim); }
    .resume-contact { font-size: 9pt; color: var(--ink-dim); }
    .contact-screen { display: none; }
    .contact-print {
      display: inline;
      color: var(--ink-dim);
    }
    .resume-section { margin-bottom: 3pt; page-break-inside: auto; }
    .resume-section h2 {
      font-size: 8.5pt;
      margin-bottom: 2pt;
      padding-bottom: 1.5pt;
      color: var(--ink-dim);
      letter-spacing: 0.12em;
    }
    .resume-summary { font-size: 9pt; line-height: 1.25; }
    .resume-entries { gap: 4pt; }
    .resume-entry-header { column-gap: 12pt; }
    .resume .entry-body { padding-top: 1pt !important; }
    .entry-titles h3 { font-size: 10.5pt; }
    .entry-company { font-size: 8.5pt; margin-top: 1pt; color: var(--ink-dim); }
    .entry-dates { font-size: 8.5pt; color: var(--ink-dim); }
    .entry-bullets li { font-size: 9pt; line-height: 1.26; padding-left: 10pt; }
    .entry-bullets li::before { top: 0.55em; width: 4pt; }
    .entry-bullets { gap: 1.5pt; }
    /* Print Skills as a 2-column grid (each cell still label:values).
       Halves the vertical footprint vs the screen's stacked layout
       without sacrificing readability. */
    .resume-skills { grid-template-columns: 1fr 1fr; column-gap: 16pt; gap: 4pt; }
    .skill-row { grid-template-columns: 88pt 1fr; gap: 7pt; }
    .skill-row dt {
      font-size: 8pt;
      color: var(--ink-dim);
      letter-spacing: 0.1em;
    }
    .skill-row dd { font-size: 9.5pt; line-height: 1.3; }
    /* Interests inlined as a single row tacked onto the bottom of Skills —
       its dedicated section + h2 + 1-line paragraph was just barely
       overflowing page 1 with the break-after:avoid keeping the h2 tied
       to the line. Flat single-row formatting drops its vertical
       footprint to a single line and removes the section gap so it
       always fits. */
    .resume-section:has(.resume-interests) {
      margin-top: 3pt;
      margin-bottom: 0;
    }
    .resume-section:has(.resume-interests) > h2 {
      display: inline-block;
      font-size: 8pt;
      border: none;
      padding: 0;
      margin: 0 6pt 0 0;
      vertical-align: baseline;
      color: var(--ink-dim);
      letter-spacing: 0.1em;
    }
    .resume-interests {
      display: inline;
      font-size: 9pt;
    }
    .resume-foot { display: none; }

    /* Page-break discipline — per Codex, scope to entries not whole section */
    h1, h2, h3 { break-after: avoid; page-break-after: avoid; }
    .resume-entry { break-inside: avoid; page-break-inside: avoid; }
    .entry-bullets li { break-inside: avoid; page-break-inside: avoid; }
    p, li { orphans: 2; widows: 2; }
  }
</style>
