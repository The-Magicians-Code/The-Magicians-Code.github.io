---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects · Tanel Treuberg"
  description="Software engineering projects by Tanel Treuberg, including TensorRT-optimised computer vision and embedded controllers."
  canonicalPath="/projects/"
>
  <main class="projects-page">
    <header class="projects-header section-fade-in" style="--delay: 0.1s">
      <div class="section-eyebrow">Index</div>
      <h1 class="projects-title">Selected <em>work</em>.</h1>
    </header>
    <section class="section-fade-in" style="--delay: 0.2s">
      <div class="projects-grid">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            repoUrl={project.data.repoUrl}
            slug={project.id}
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .projects-page {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  @media (min-width: 720px) {
    .projects-page { padding: 0 40px; }
  }
  .projects-header { padding-top: 24px; }
  .projects-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 4vw + 1rem, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 720px) {
    .projects-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
