---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import BentoProjectsSection from '../components/BentoProjectsSection.astro';
import BentoStackSection from '../components/BentoStackSection.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
  title="Tanel Treuberg - SWE"
  description="Software engineer working across backend, infrastructure, and applied ML."
  canonicalPath="/"
  includePersonSchema={true}
>
  <Hero />
  <main class="page">
    <About />
    <BentoProjectsSection />
    <BentoStackSection />
    <Contact />
  </main>
</BaseLayout>

<style>
  .page {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }
  @media (min-width: 720px) {
    .page {
      padding: 0 40px;
      gap: 88px;
    }
  }
</style>
