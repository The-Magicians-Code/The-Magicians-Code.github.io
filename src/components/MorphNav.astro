---
/**
 * MorphNav — a self-contained morphing "pill" navigation (mobile-only),
 * ported from docs/ideas/ravalabs-nav-artifact.html into a props-driven
 * Astro component and repurposed as the site's mobile nav.
 *
 * Three shell states are driven by CSS classes on the <nav class="morph-nav"> root:
 *   .is-intro   — tiny squircle (spark glyph only), shown for `introMs` on load
 *   .is-compact — 43px bar: active section title + glyph
 *   .is-open    — expanded panel: the vertical nav links (height measured at runtime)
 *
 * Page contract: the IntersectionObserver in the client script observes every
 * element on the page carrying `data-nav-section="<id>"`. Those ids should match
 * the `id`s in the `sections` prop. The host page owns those section elements;
 * this component only reads them.
 */
import ThemeToggle from "./ThemeToggle.astro";
import { Icon } from "astro-icon/components";

export interface NavSection {
  /** Must match a `data-nav-section` on the host page. First entry = hero/brand. */
  id: string;
  /** Label shown in the title reel. */
  title: string;
}
export interface NavLink {
  label: string;
  href: string;
  /** Open in a new tab (e.g. the build-time resume PDF). */
  external?: boolean;
  /** Iconify icon name (e.g. "lucide:user"), shown left of the label to align
   *  with the theme toggle's icon. */
  icon?: string;
}

interface Props {
  sections?: NavSection[];
  /** Dropdown nav list rendered as full-width tappable rows. */
  links?: NavLink[];
  /** Play the on-load morph (squircle pill → compact bar). When false the nav
   *  renders directly in its compact resting shape with no entrance animation. */
  intro?: boolean;
  /** Hold time on the intro pill before auto-open (ms). Ignored when intro is false. */
  introMs?: number;
  /** Auto-open once after the intro. */
  autoOpen?: boolean;
  /** Render the ThemeToggle as the last row of the dropdown body. */
  themeToggle?: boolean;
}

const {
  sections = [
    { id: "hero", title: "Home" },
    { id: "about", title: "About" },
    { id: "projects", title: "Work" },
    { id: "skills-tools", title: "Stack" },
    { id: "contact", title: "Contact" },
  ],
  links = [
    { label: "About", href: "/#about", icon: "lucide:user" },
    { label: "Work", href: "/#projects", icon: "lucide:briefcase" },
    { label: "Stack", href: "/#skills-tools", icon: "lucide:layers" },
    { label: "Resume", href: "/Tanel_Treuberg_Software_Engineer.pdf", external: true, icon: "lucide:file-text" },
    { label: "Contact", href: "/#contact", icon: "lucide:mail" },
  ],
  intro = true,
  introMs = 2100,
  autoOpen = true,
  themeToggle = false,
} = Astro.props;

const heroId = sections[0]?.id ?? "hero";
---

<nav
  class:list={["morph-nav", { "is-intro": intro }, "is-compact"]}
  data-section={heroId}
  data-intro-ms={String(introMs)}
  data-auto-open={String(autoOpen)}
  aria-label="Site navigation"
>
  <div class="morph-top" role="button" tabindex="0" aria-expanded="false">
    <div class="morph-title-window">
      <div class="morph-title-stack">
        {sections.map((s) => (
          <div class:list={["morph-title-line", { "is-active": s.id === heroId }]} data-id={s.id}>{s.title}</div>
        ))}
      </div>
    </div>
    <div class="morph-action" aria-hidden="true">
      <div class="morph-progress-glyph">
        <svg viewBox="0 0 29 29">
          <circle class="morph-progress-track" cx="14.5" cy="14.5" r="12"></circle>
          <circle class="morph-progress-ring" cx="14.5" cy="14.5" r="12"></circle>
        </svg>
      </div>
    </div>
  </div>

  <div class="morph-body" inert>
    {links.length > 0 && (
      <div class="morph-links">
        {links.map((link) => (
          <a
            class="morph-link"
            href={link.href}
            {...(link.external ? { target: "_blank", rel: "noopener" } : {})}
          >
            {link.icon && <Icon name={link.icon} class="morph-link-icon" aria-hidden="true" />}
            <span class="morph-link-label">{link.label}</span>
          </a>
        ))}
      </div>
    )}
    {themeToggle && (
      <div class="morph-theme-row">
        <ThemeToggle />
      </div>
    )}
  </div>

  <span class="morph-live" aria-live="polite"></span>
</nav>

<style>
  .morph-nav {
    /* Light-mode tokens derived from the site theme (src/styles/global.css). */
    --morph-panel: rgba(250, 248, 243, 0.82);
    --morph-ink: var(--ink, #1a1a1c);
    --morph-muted: var(--ink-3, #8e8a82);
    --morph-line: var(--rule, rgba(26, 26, 28, 0.12));
    --morph-shadow: 0 18px 60px rgba(26, 26, 28, 0.12);
    --morph-accent: var(--accent, oklch(64% 0.18 28));

    position: fixed;
    top: 20px;
    left: 50%;
    z-index: 20;
    width: min(350px, calc(100vw - 40px));
    transform: translateX(-50%);
    overflow: hidden;
    border-radius: 20px;
    background: var(--morph-panel);
    box-shadow: var(--morph-shadow);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--morph-ink);
    -webkit-user-select: none;
    user-select: none;
    transition:
      width 1000ms cubic-bezier(.44, 0, .08, 1),
      height 1000ms cubic-bezier(.44, 0, .08, 1),
      border-radius 1000ms cubic-bezier(.44, 0, .08, 1);
  }

  html.dark .morph-nav {
    --morph-panel: rgba(20, 20, 26, 0.82);
    --morph-ink: var(--ink, #f0f0f5);
    --morph-muted: var(--ink-3, #5c5c68);
    --morph-line: var(--rule, rgba(255, 255, 255, 0.10));
    --morph-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
    --morph-accent: var(--accent, oklch(72% 0.16 28));
  }

  .morph-nav * {
    box-sizing: border-box;
  }

  .morph-nav.is-intro {
    width: 43px;
    height: 43px;
    border-radius: 18px;
    transition-duration: 1400ms;
  }

  .morph-nav.is-compact {
    height: 43px;
  }

  .morph-nav.is-open {
    /* Measured from content at runtime; 286px is the artifact default fallback. */
    height: var(--morph-open-height, 286px);
  }

  /* Only when content genuinely exceeds the viewport (set by the client script).
     The base `overflow: hidden` otherwise keeps the morph-reveal clean — no
     scrollbar flicker while the height animates open. */
  .morph-nav.is-open[data-scroll="true"] {
    overflow-y: auto;
  }

  .morph-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 43px;
    padding: 8px 8px 8px 14px;
    cursor: pointer;
  }

  .morph-nav.is-intro .morph-top {
    justify-content: center;
    padding: 0;
  }

  .morph-title-window {
    position: relative;
    width: 113px;
    height: 27px;
    overflow: hidden;
  }

  .morph-nav.is-intro .morph-title-window {
    display: none;
  }

  /* All titles overlap in one cell; only the active one is shown. Switching
     section blur-cross-fades between them (no vertical slide). */
  .morph-title-stack {
    display: grid;
  }

  .morph-title-line {
    grid-area: 1 / 1;
    height: 27px;
    font-size: 1rem;
    line-height: 22px;
    white-space: nowrap;
    display: flex;
    align-items: center;
    opacity: 0;
    filter: blur(2px);
    transition:
      opacity 0.22s ease-out,
      filter 0.22s ease-out;
  }

  .morph-title-line.is-active {
    opacity: 1;
    filter: blur(0);
  }

  .morph-action {
    position: relative;
    width: 41px;
    height: 27px;
    overflow: hidden;
  }

  .morph-nav.is-intro .morph-action {
    width: 27px;
  }

  /* The progress ring is the only glyph: hidden at the top of the page, it
     fades in once the user starts scrolling (and out again at the top, or while
     the panel is open). is-scrolled is toggled from the scroll rAF loop. */
  .morph-progress-glyph {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    transition: opacity 250ms ease;
  }

  .morph-nav.is-scrolled:not(.is-open) .morph-progress-glyph {
    opacity: 1;
  }

  .morph-progress-glyph svg {
    width: 29px;
    height: 29px;
    transform: rotate(-87deg);
  }

  .morph-progress-track,
  .morph-progress-ring {
    fill: none;
    stroke-width: 2.3;
  }

  .morph-progress-track {
    stroke: var(--morph-line);
  }

  .morph-progress-ring {
    stroke: var(--morph-accent);
    stroke-linecap: round;
    /* No transition: the offset is updated once per animation frame from the
       live scroll position (see the rAF loop in the script), so it tracks
       scroll 1:1. A transition here would make it lag/step behind on Safari. */
  }

  .morph-body {
    display: flex;
    flex-direction: column;
    gap: 0;
    /* Inset padding so each item's rounded hit-area floats clear of the panel
       edges (like prod's mobile menu / the theme toggle's pill). */
    padding: 8px;
    opacity: 0;
    filter: blur(10px);
    pointer-events: none;
    transition:
      opacity 300ms cubic-bezier(.5, 0, .88, .77),
      filter 300ms cubic-bezier(.5, 0, .88, .77);
  }

  .morph-nav.is-open .morph-body {
    opacity: 1;
    filter: blur(0);
    pointer-events: auto;
  }

  /* Vertical nav list: each item is its own rounded clickable area. */
  .morph-links {
    display: flex;
    flex-direction: column;
    padding: 0;
  }

  .morph-link {
    display: flex;
    align-items: center;
    gap: 7px;
    min-height: 44px;
    padding: 12px 16px;
    border-radius: 12px;
    color: var(--morph-ink);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  /* 20px icon column + 7px gap mirrors the theme toggle (.tt-icons + gap), so
     link icons and the toggle icon share one vertical line, labels another. */
  .morph-link-icon {
    width: 20px;
    height: 20px;
    flex: none;
    color: var(--morph-muted);
  }

  .morph-link:hover,
  .morph-link:active {
    background: rgba(128, 128, 128, 0.15);
  }

  .morph-theme-row {
    display: flex;
    align-items: center;
    padding: 0;
  }

  /* Give the toggle the same rounded clickable area as the link items: it fills
     the inset row width, its icon shares the link icons' gutter, and the label
     matches the dropdown's 1rem size. */
  .morph-theme-row :global(.theme-toggle-btn) {
    width: 100%;
    height: 44px;
    justify-content: flex-start;
    padding: 0 16px;
    border-radius: 12px;
  }

  .morph-theme-row :global(.tt-label) {
    font-size: 1rem;
  }

  .morph-live {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .morph-nav,
    .morph-title-line,
    .morph-progress-glyph,
    .morph-body {
      transition-duration: 1ms !important;
    }
  }

  /* Desktop-hide self-guard: the component is mobile-only. */
  @media (min-width: 641px) {
    .morph-nav {
      display: none;
    }
  }
</style>

<script>
  type NavState = "intro" | "open" | "compact";

  function initMorphNav(nav: HTMLElement) {
    if (nav.dataset.morphReady) return;
    nav.dataset.morphReady = "true";

    const navTop = nav.querySelector<HTMLElement>(".morph-top");
    const navBody = nav.querySelector<HTMLElement>(".morph-body");
    const titleStack = nav.querySelector<HTMLElement>(".morph-title-stack");
    const ring = nav.querySelector<SVGCircleElement>(".morph-progress-ring");
    const live = nav.querySelector<HTMLElement>(".morph-live");
    const lines = Array.from(nav.querySelectorAll<HTMLElement>(".morph-title-line"));
    const sectionIds = lines.map((l) => l.dataset.id ?? "");

    if (!navTop || !navBody || !titleStack || !lines.length) return;

    const heroId = sectionIds[0];
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const introMs = reduceMotion ? 0 : Number(nav.dataset.introMs) || 2100;
    const autoOpen = nav.dataset.autoOpen !== "false";

    // Progress ring geometry (r=12, matches the SVG markup).
    const circumference = 2 * Math.PI * 12;
    if (ring) {
      ring.style.strokeDasharray = String(circumference);
      ring.style.strokeDashoffset = String(circumference);
    }

    // Measure at the true open width (compact and open share the same width;
    // only `is-intro` is 43px). We freeze transitions and momentarily drop
    // `is-intro` so the content lays out at full width, read it, then restore
    // the prior state — all synchronously, so no intermediate frame paints and
    // the intro morph still plays normally afterwards. Measuring while the
    // intro→compact width animation is mid-flight would inflate scrollHeight
    // (narrow shell ⇒ text wraps tall) and leave dead space once it settles.
    function measure() {
      // Bail when the element is not rendered (e.g. hidden on desktop). The root
      // is position:fixed, so offsetParent is null even when visible — use
      // getClientRects() instead.
      if (nav.getClientRects().length === 0) return;

      const prevTransition = nav.style.transition;
      const wasIntro = nav.classList.contains("is-intro");
      nav.style.transition = "none";
      if (wasIntro) nav.classList.remove("is-intro");
      void nav.offsetWidth; // reflow at full width

      const full = navTop!.offsetHeight + navBody!.scrollHeight;
      const cap = window.innerHeight - 40;
      nav.style.setProperty("--morph-open-height", `${Math.min(full, cap)}px`);
      // Enable internal scrolling only when content truly overflows the viewport.
      nav.dataset.scroll = String(full > cap);

      if (wasIntro) {
        nav.classList.add("is-intro");
        void nav.offsetWidth; // snap back without animating
      }
      nav.style.transition = prevTransition;
    }

    function setReel() {
      const open = nav.classList.contains("is-open");
      const activeId = open ? heroId : (nav.dataset.section ?? heroId);
      lines.forEach((line) => {
        line.classList.toggle("is-active", line.dataset.id === activeId);
      });
    }

    function currentState(): NavState {
      if (nav.classList.contains("is-intro")) return "intro";
      return nav.classList.contains("is-open") ? "open" : "compact";
    }

    function syncReadouts() {
      if (live) {
        const idx = sectionIds.indexOf(nav.dataset.section ?? heroId);
        live.textContent = idx >= 0 ? lines[idx].textContent : (nav.dataset.section ?? "");
      }
      document.dispatchEvent(
        new CustomEvent("morph-nav:change", {
          detail: { state: currentState(), section: nav.dataset.section },
        }),
      );
    }

    function setExpanded(open: boolean) {
      nav.classList.toggle("is-open", open);
      nav.classList.toggle("is-compact", !open);
      navTop!.setAttribute("aria-expanded", String(open));
      navBody!.inert = !open;
      setReel();
      syncReadouts();
    }

    function toggleExpanded() {
      if (nav.classList.contains("is-intro")) return;
      setExpanded(!nav.classList.contains("is-open"));
    }

    navTop.addEventListener("click", toggleExpanded);
    navTop.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        toggleExpanded();
      }
    });

    // Collapse the panel when a nav link is tapped, before the in-page anchor
    // scroll runs (mirrors MobileMenu.astro).
    nav.querySelectorAll<HTMLAnchorElement>(".morph-link").forEach((link) => {
      link.addEventListener("click", () => setExpanded(false));
    });

    // Cache the open height up front (width-safe), before any intro morph plays.
    measure();

    if (nav.classList.contains("is-intro")) {
      // Intro morph → after the hold, drop the squircle and settle into the
      // target state (the height var is already correct).
      window.setTimeout(() => {
        nav.classList.remove("is-intro");
        setExpanded(autoOpen);
      }, introMs);
    } else {
      // Intro disabled: the nav is already in its compact resting shape; just
      // settle aria/reel state (and auto-open if the host requested it).
      setExpanded(autoOpen);
    }

    // Scrollspy. Sections are owned by the host page; this is the documented
    // [data-nav-section] contract.
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (!visible) return;

        const target = visible.target as HTMLElement;
        const id = target.dataset.navSection ?? heroId;
        const known = sectionIds.includes(id);
        if (!known) console.warn("[morph-nav] observed unknown section id:", id);

        nav.dataset.section = known ? id : heroId;

        if (known && id !== heroId) {
          setExpanded(false);
        } else {
          setReel();
          syncReadouts();
        }
      },
      // Active section = whichever crosses a line near the top of the viewport,
      // so the header changes as a section reaches the top (not its 50%-of-area,
      // which flipped to a short section while it was still peeking up from the
      // bottom).
      { rootMargin: "-10% 0px -90% 0px", threshold: 0 },
    );
    document
      .querySelectorAll<HTMLElement>("[data-nav-section]")
      .forEach((section) => observer.observe(section));

    function updateProgress() {
      if (!ring) return;
      // Reveal the ring only once the user has actually started scrolling; at the
      // very top show the resting spark instead (small dead-zone avoids flicker).
      nav.classList.toggle("is-scrolled", window.scrollY > 8);
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const progress = max <= 0 ? 0 : window.scrollY / max;
      ring.style.strokeDashoffset = String(
        circumference * (1 - Math.min(1, Math.max(0, progress))),
      );
    }

    let resizeRaf = 0;
    function onResize() {
      window.cancelAnimationFrame(resizeRaf);
      resizeRaf = window.requestAnimationFrame(() => {
        if (!nav.classList.contains("is-intro")) measure();
        updateProgress();
      });
    }

    // Drive the progress ring from a rAF loop, not the scroll event directly:
    // it reads the live scrollY each frame while the page is moving (smooth even
    // during iOS Safari momentum, where scroll events arrive in uneven bursts)
    // and parks itself once the position settles.
    let progressRaf = 0;
    let progressPrevY = NaN;
    function progressTick() {
      updateProgress();
      const y = window.scrollY;
      if (y !== progressPrevY) {
        progressPrevY = y;
        progressRaf = window.requestAnimationFrame(progressTick);
      } else {
        progressRaf = 0;
      }
    }
    function onScroll() {
      progressPrevY = NaN; // force the loop to keep ticking while scrolling
      if (!progressRaf) progressRaf = window.requestAnimationFrame(progressTick);
    }

    updateProgress();
    syncReadouts();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize);
  }

  document.querySelectorAll<HTMLElement>(".morph-nav").forEach(initMorphNav);
</script>
