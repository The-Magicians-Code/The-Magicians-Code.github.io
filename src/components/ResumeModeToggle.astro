---
// Formal / Interactive pill toggle. Mirrors the TldrToggle visual language
// but flips a different class on the closest [data-resume-scope] ancestor.
// Defaults to Interactive — the scope is pre-marked .is-interactive in
// resume.astro to avoid FOUC on first paint.

interface Props {
  defaultMode?: 'formal' | 'interactive';
}
const { defaultMode = 'interactive' } = Astro.props;
---

<div
  class="rm-bar"
  data-resume-mode-toggle
  data-state={defaultMode}
  role="group"
  aria-label="Resume presentation mode"
>
  <span class="rm-indicator" aria-hidden="true"></span>
  <button
    type="button"
    class:list={['rm-pill', defaultMode === 'formal' && 'rm-pill--active']}
    data-mode="formal"
    aria-pressed={defaultMode === 'formal' ? 'true' : 'false'}
  >
    Formal
  </button>
  <button
    type="button"
    class:list={['rm-pill', defaultMode === 'interactive' && 'rm-pill--active']}
    data-mode="interactive"
    aria-pressed={defaultMode === 'interactive' ? 'true' : 'false'}
  >
    Interactive
  </button>
</div>

<style>
  .rm-bar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    gap: 4px;
    padding: 4px;
    border-radius: 999px;
    background: var(--accent-soft);
    border: 1px solid var(--accent-soft);
    position: relative;
    isolation: isolate;
    width: max-content;
  }
  .rm-indicator {
    grid-row: 1;
    grid-column: 1;
    background: var(--bg);
    border-radius: 999px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08), inset 0 0 0 1px rgba(0, 0, 0, 0.04);
    z-index: 0;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .rm-bar[data-state="interactive"] .rm-indicator {
    transform: translateX(calc(100% + 4px));
  }
  .rm-pill {
    grid-row: 1;
    z-index: 1;
    border: 0;
    background: transparent;
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    text-align: center;
    transition: color 240ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .rm-pill:nth-of-type(1) { grid-column: 1; }
  .rm-pill:nth-of-type(2) { grid-column: 2; }
  .rm-pill:hover { color: var(--ink-dim); }
  .rm-pill--active { color: var(--ink); }
  .rm-pill:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .rm-indicator,
    .rm-pill {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-resume-mode-toggle]').forEach((bar) => {
    const scope = bar.closest<HTMLElement>('[data-resume-scope]');
    if (!scope) return;
    const pills = bar.querySelectorAll<HTMLButtonElement>('.rm-pill');
    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const mode = pill.dataset.mode ?? 'interactive';
        bar.dataset.state = mode;
        pills.forEach((p) => {
          const active = p.dataset.mode === mode;
          p.classList.toggle('rm-pill--active', active);
          p.setAttribute('aria-pressed', String(active));
        });
        scope.classList.toggle('is-interactive', mode === 'interactive');
        scope.classList.toggle('is-formal', mode === 'formal');
      });
    });
  });
</script>
