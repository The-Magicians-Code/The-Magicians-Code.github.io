---
interface Props {
  label?: string;
}
const { label = 'Detail level' } = Astro.props;
---

<div class="tldr-bar" data-tldr-toggle data-state="detailed" role="group" aria-label={label}>
  <span class="tldr-indicator" aria-hidden="true"></span>
  <button type="button" class="tldr-pill tldr-pill--active" data-tldr-mode="detailed" aria-pressed="true">
    Detailed
  </button>
  <button type="button" class="tldr-pill" data-tldr-mode="tldr" aria-pressed="false">
    TL;DR
  </button>
</div>

<style>
  .tldr-bar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    gap: 4px;
    padding: 4px;
    border-radius: 999px;
    background: var(--accent-soft);
    border: 1px solid var(--accent-soft);
    position: relative;
    isolation: isolate;
    width: max-content;
  }
  .tldr-indicator {
    grid-row: 1;
    grid-column: 1;
    background: var(--bg);
    border-radius: 999px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08), inset 0 0 0 1px rgba(0, 0, 0, 0.04);
    z-index: 0;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .tldr-bar[data-state="tldr"] .tldr-indicator {
    transform: translateX(calc(100% + 4px));
  }
  .tldr-pill {
    grid-row: 1;
    z-index: 1;
    border: 0;
    background: transparent;
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    text-align: center;
    transition: color 240ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .tldr-pill:nth-of-type(1) { grid-column: 1; }
  .tldr-pill:nth-of-type(2) { grid-column: 2; }
  .tldr-pill:hover { color: var(--ink-dim); }
  .tldr-pill--active { color: var(--ink); }
  .tldr-pill:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .tldr-indicator,
    .tldr-pill {
      transition: none;
    }
  }
</style>

<style is:global>
  [data-tldr-collapsible] {
    display: grid;
    grid-template-rows: 1fr;
    transition:
      grid-template-rows 320ms cubic-bezier(0.22, 1, 0.36, 1),
      margin 320ms cubic-bezier(0.22, 1, 0.36, 1),
      padding 320ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 240ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-tldr-collapsible] > * {
    min-height: 0;
    overflow: hidden;
  }
  .is-tldr [data-tldr-collapsible] {
    grid-template-rows: 0fr;
    opacity: 0;
    margin: 0;
    padding: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-tldr-collapsible] {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-tldr-toggle]').forEach((bar) => {
    const scope = bar.closest<HTMLElement>('[data-tldr-scope]');
    if (!scope) return;
    const pills = bar.querySelectorAll<HTMLButtonElement>('.tldr-pill');
    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const mode = pill.dataset.tldrMode ?? 'detailed';
        bar.dataset.state = mode;
        pills.forEach((p) => {
          const active = p.dataset.tldrMode === mode;
          p.classList.toggle('tldr-pill--active', active);
          p.setAttribute('aria-pressed', String(active));
        });
        scope.classList.toggle('is-tldr', mode === 'tldr');
      });
    });
  });
</script>
