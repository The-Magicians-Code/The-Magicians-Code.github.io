---
import { Icon } from 'astro-icon/components';
---

<button class="theme-toggle-btn" type="button" aria-label="Toggle theme">
  <span class="tt-icons" aria-hidden="true">
    <Icon name="lucide:sun" class="icon-sun" />
    <Icon name="lucide:moon" class="icon-moon" />
  </span>
  <span class="tt-label" aria-hidden="true">
    <span class="lbl-sol">Sol</span>
    <span class="lbl-lua">Lua</span>
  </span>
</button>

<style is:global>
  .theme-toggle-btn {
    height: 36px;
    border-radius: 9999px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 0 12px 0 10px;
    color: var(--ink-dim);
    transition: color 0.2s ease, background-color 0.2s ease, transform 0.15s ease-out;
    cursor: pointer;
  }

  .theme-toggle-btn:hover {
    color: var(--ink);
    background-color: rgba(128, 128, 128, .15);
  }

  /* Subtle press dip — feels responsive, animations.dev copy-button style. */
  .theme-toggle-btn:active {
    transform: scale(0.97);
  }

  /* Sun/moon icons stacked on top of each other so the theme swap can
     cross-fade instead of hard-swapping via display:none. */
  .theme-toggle-btn .tt-icons {
    position: relative;
    flex: none;
    width: 20px;
    height: 20px;
  }
  .theme-toggle-btn .icon-sun,
  .theme-toggle-btn .icon-moon {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 20px;
    height: 20px;
  }

  /* Sol/Lua label — both words share one grid cell so the pill width is the
     widest word (no reflow on toggle); they cross-fade like the icons. */
  .theme-toggle-btn .tt-label {
    display: grid;
    font-size: 13px;
    font-weight: 500;
    line-height: 1;
  }
  .theme-toggle-btn .tt-label > span {
    grid-area: 1 / 1;
  }

  /* Shared cross-fade: blur + scale + opacity at 0.15s ease-out. The blur
     blends the two states so the swap reads as a smooth melt, not a cut. */
  .theme-toggle-btn .icon-sun,
  .theme-toggle-btn .icon-moon,
  .theme-toggle-btn .tt-label > span {
    transition: opacity 0.15s ease-out, transform 0.15s ease-out, filter 0.15s ease-out;
  }

  /* Light mode: Sol + sun active; moon + Lua parked (blurred, shrunk, hidden). */
  .theme-toggle-btn .icon-moon,
  .theme-toggle-btn .lbl-lua {
    opacity: 0;
    transform: scale(0.6);
    filter: blur(2px);
  }
  .theme-toggle-btn .icon-sun,
  .theme-toggle-btn .lbl-sol {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
  }
  /* Dark mode: the reverse. */
  html.dark .theme-toggle-btn .icon-sun,
  html.dark .theme-toggle-btn .lbl-sol {
    opacity: 0;
    transform: scale(0.6);
    filter: blur(2px);
  }
  html.dark .theme-toggle-btn .icon-moon,
  html.dark .theme-toggle-btn .lbl-lua {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle-btn,
    .theme-toggle-btn .icon-sun,
    .theme-toggle-btn .icon-moon,
    .theme-toggle-btn .tt-label > span {
      transition: none;
    }
    .theme-toggle-btn:active {
      transform: none;
    }
  }
</style>

<script>
  import { applyTheme } from '../lib/theme';

  document
    .querySelectorAll('.theme-toggle-btn')
    .forEach((b) => b.addEventListener('click', () => applyTheme('toggle')));
</script>
