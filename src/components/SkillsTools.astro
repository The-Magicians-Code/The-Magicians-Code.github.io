---
const groups: { label: string; items: string[] }[] = [
  {
    label: 'Languages',
    items: ['Python', 'C++', 'JavaScript', 'SQL', 'Bash', 'Swift'],
  },
  {
    label: 'ML / AI',
    items: ['PyTorch', 'TensorFlow', 'TensorRT', 'ONNX', 'OpenCV', 'GStreamer', 'Nvidia Jetson'],
  },
  {
    label: 'Infra & DevOps',
    items: ['Docker', 'Jenkins', 'GitLab CI/CD', 'AWS S3', 'Grafana', 'ELK', 'Kubernetes'],
  },
  {
    label: 'Frameworks & Tools',
    items: ['Flask', 'REST APIs', 'PostgreSQL', 'Selenium', 'Scrapy', 'Postman', 'Git'],
  },
];
---

<section id="skills-tools" class="section-fade-in" style="--delay: 0.3s">
  <div class="section-eyebrow">04 · Stack</div>
  <h2 class="section-title">Tools I <em>actually</em> reach for.</h2>
  <div class="stack-groups">
    {groups.map((group) => (
      <div class="stack-group">
        <div class="stack-label">{group.label}</div>
        <div class="stack-items">
          {group.items.map((item) => (
            <span class="pill">{item}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .section-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 1.5vw + 1.25rem, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 24px;
  }
  .stack-groups {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
  }
  @media (min-width: 720px) {
    .stack-groups { grid-template-columns: 1fr 1fr; gap: 28px 32px; }
  }
  .stack-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--ink-3);
    margin-bottom: 10px;
  }
  .stack-items {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
</style>
