---
import TldrToggle from './TldrToggle.astro';

type Group = { label: string; icon: string; items: string[] };

const groups: Group[] = [
  {
    label: 'Languages',
    icon: 'code',
    items: ['Python', 'C++', 'JavaScript', 'SQL', 'Bash', 'Swift'],
  },
  {
    label: 'ML / AI',
    icon: 'network',
    items: ['PyTorch', 'TensorFlow', 'TensorRT', 'ONNX', 'OpenCV', 'GStreamer', 'Nvidia Jetson'],
  },
  {
    label: 'Infra & DevOps',
    icon: 'servers',
    items: ['Docker', 'Jenkins', 'GitLab CI/CD', 'AWS S3', 'Grafana', 'ELK', 'Kubernetes'],
  },
  {
    label: 'Frameworks & Tools',
    icon: 'wrench',
    items: ['Flask', 'REST APIs', 'PostgreSQL', 'Selenium', 'Scrapy', 'Postman', 'Git'],
  },
];
---

<section id="skills-tools" class="section-fade-in" data-tldr-scope style="--delay: 0.3s">
  <div class="skills-head">
    <div>
      <div class="section-eyebrow">04 · Stack</div>
      <h2 class="section-title">Tools I <em>actually</em> reach for.</h2>
    </div>
    <TldrToggle label="Stack detail level" />
  </div>
  <div class="stack-grid">
    {groups.map((group) => (
      <div class="stack-cell bento">
        <div class="stack-head">
          <svg class="stack-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            {group.icon === 'code' && (
              <>
                <path d="m8 7-5 5 5 5" />
                <path d="m16 7 5 5-5 5" />
                <path d="m14 4-4 16" />
              </>
            )}
            {group.icon === 'network' && (
              <>
                <circle cx="4" cy="6" r="1.4" />
                <circle cx="4" cy="12" r="1.4" />
                <circle cx="4" cy="18" r="1.4" />
                <circle cx="12" cy="9" r="1.4" />
                <circle cx="12" cy="15" r="1.4" />
                <circle cx="20" cy="12" r="1.4" />
                <path d="M5.4 6 10.6 9M5.4 12 10.6 9M5.4 12 10.6 15M5.4 18 10.6 15M13.4 9 18.6 12M13.4 15 18.6 12" />
              </>
            )}
            {group.icon === 'servers' && (
              <>
                <rect x="3" y="4" width="18" height="6" rx="1.5" />
                <rect x="3" y="14" width="18" height="6" rx="1.5" />
                <path d="M7 7h.01M7 17h.01" />
              </>
            )}
            {group.icon === 'wrench' && (
              <path d="M14.7 6.3a4.5 4.5 0 0 0-6.06 5.94l-5.94 5.94 2.12 2.12 5.94-5.94a4.5 4.5 0 0 0 5.94-6.06l-2.72 2.72-2.12-2.12 2.84-2.6z" />
            )}
          </svg>
          <h4 class="stack-label">{group.label}</h4>
        </div>
        <div class="stack-list-wrap" data-tldr-collapsible>
          <div class="stack-list">
            {group.items.map((item, idx) => (
              <div class="stack-list-item">{idx === 0 ? <em>{item}</em> : item}</div>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .section-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 1.5vw + 1.25rem, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 0;
  }
  .skills-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px 24px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .stack-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 560px) {
    .stack-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 960px) {
    .stack-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .stack-cell {
    display: flex;
    flex-direction: column;
  }
  :global(.is-tldr) .stack-cell {
    justify-content: center;
  }
  .stack-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .stack-icon {
    width: 20px;
    height: 20px;
    color: var(--accent);
    flex-shrink: 0;
  }
  .stack-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    margin: 0;
  }
  .stack-list-wrap {
    padding-top: 18px;
  }
  :global(.is-tldr) .stack-list-wrap {
    padding-top: 0;
  }
  .stack-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .stack-list-item {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.2;
    color: var(--ink);
  }
  .stack-list-item em {
    font-style: italic;
    color: var(--accent);
  }
</style>
