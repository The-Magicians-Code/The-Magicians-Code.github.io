---
// Tech-stack section. Single paper bento card with the title centered
// at rest (via the shared --title-rest-y JS-measured translateY pattern
// from bento-expand.ts), and the per-word pretext morph wiring the
// title's words to their modal positions during expand.
//
// Rest state shows only the title — same content shape as project
// case-study cards (BentoCard.astro), so the pretext + title-rest-y
// contract holds. The full categorized stack lives inside the hidden
// .bento-card-body, cloned into a two-column split on expand.
//
// `data-no-mode-toggle` opts out of the TL;DR ↔ Detailed pill that
// project case-studies use — this card has only one content mode.
//
// Preserves the #skills-tools anchor for Nav.astro / MobileMenu.astro.
---

<article
  id="skills-tools"
  class="bento-card stack-card"
  data-bento-card
  data-slug="stack"
  data-no-mode-toggle
  role="button"
  tabindex="0"
  aria-haspopup="dialog"
  aria-expanded="false"
  aria-label="Tools I actually reach for"
>
  <span class="cs-expand" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 3 21 3 21 9" />
      <polyline points="9 21 3 21 3 15" />
      <line x1="21" y1="3" x2="14" y2="10" />
      <line x1="3" y1="21" x2="10" y2="14" />
    </svg>
  </span>

  <div class="card-body">
    <div class="card-title">Tools I <em>actually</em> reach for</div>
  </div>

  <!-- Cloned into a visible .bento-card-body-rendered on expand. Two
       sub-cards inside — one for the languages, one for the tools. -->
  <div class="bento-card-body" hidden>
    <div class="stack-split">
      <article class="stack-split-card">
        <h3 class="stack-split-title">Languages I <em>think in</em></h3>

        <h4>Languages</h4>
        <ul class="stack-chip-row">
          <li class="stack-chip"><em>Python</em></li>
          <li class="stack-chip">C++</li>
          <li class="stack-chip">JavaScript</li>
          <li class="stack-chip">SQL</li>
          <li class="stack-chip">Bash</li>
          <li class="stack-chip">Swift</li>
        </ul>

        <h4>ML / AI</h4>
        <ul class="stack-chip-row">
          <li class="stack-chip"><em>PyTorch</em></li>
          <li class="stack-chip">TensorFlow</li>
          <li class="stack-chip">TensorRT</li>
          <li class="stack-chip">ONNX</li>
          <li class="stack-chip">OpenCV</li>
          <li class="stack-chip">GStreamer</li>
          <li class="stack-chip">Nvidia Jetson</li>
        </ul>
      </article>

      <article class="stack-split-card">
        <h3 class="stack-split-title">Tools I <em>reach for</em></h3>

        <h4>Infra &amp; DevOps</h4>
        <ul class="stack-chip-row">
          <li class="stack-chip"><em>Docker</em></li>
          <li class="stack-chip">Jenkins</li>
          <li class="stack-chip">GitLab CI/CD</li>
          <li class="stack-chip">AWS S3</li>
          <li class="stack-chip">Grafana</li>
          <li class="stack-chip">ELK</li>
          <li class="stack-chip">Kubernetes</li>
        </ul>

        <h4>Frameworks &amp; Tools</h4>
        <ul class="stack-chip-row">
          <li class="stack-chip"><em>Flask</em></li>
          <li class="stack-chip">REST APIs</li>
          <li class="stack-chip">PostgreSQL</li>
          <li class="stack-chip">Selenium</li>
          <li class="stack-chip">Scrapy</li>
          <li class="stack-chip">Postman</li>
          <li class="stack-chip">Git</li>
        </ul>
      </article>
    </div>
  </div>
</article>

<style>
  /* Paper background, custom aspect. The .bento-card base from
     BentoGrid.astro sets aspect-ratio: 4/1; override to 3/1 for a
     slightly taller rest box. */
  :global(.bento-card.stack-card),
  :global(.bento-card.stack-card:hover) {
    background-color: var(--paper);
    cursor: pointer;
    aspect-ratio: 3 / 1;
  }
  @media (max-width: 540px) {
    :global(.bento-card.stack-card),
    :global(.bento-card.stack-card:hover) {
      aspect-ratio: 1 / 1;
    }
  }

  /* card-body inherits BentoGrid's flex column + justify-content:
     flex-start. The title is then visually pushed to the body's
     vertical center via --title-rest-y (computed in bento-expand.ts
     syncTitleRestY) — same machinery as project cards. */

  /* em inside the title inherits the global italic+accent rule and
     is rendered via pretext as <em class="word"> word spans (see
     BentoGrid.astro .pretext-title rules). */

  /* Expanded modal body — two sub-cards side by side. */
  :global(.bento-card.stack-card .bento-card-body-rendered .stack-split) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 640px) {
    :global(.bento-card.stack-card .bento-card-body-rendered .stack-split) {
      grid-template-columns: 1fr;
    }
  }
  :global(.bento-card.stack-card .bento-card-body-rendered .stack-split-card) {
    background: rgba(26, 26, 28, 0.04);
    border-radius: var(--radius-card, 14px);
    padding: 20px 22px;
  }
  :global(html.dark .bento-card.stack-card .bento-card-body-rendered .stack-split-card) {
    background: rgba(255, 255, 255, 0.05);
  }
  :global(.bento-card.stack-card .bento-card-body-rendered .stack-split-title) {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 400;
    margin: 0 0 14px;
    color: var(--ink);
  }
  :global(.bento-card.stack-card .bento-card-body-rendered h4) {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-dim);
    margin: 16px 0 8px;
  }
  :global(.bento-card.stack-card .bento-card-body-rendered h4:first-of-type) {
    margin-top: 0;
  }
  :global(.bento-card.stack-card .bento-card-body-rendered .stack-chip-row) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  :global(.bento-card.stack-card .bento-card-body-rendered .stack-chip) {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(26, 26, 28, 0.06);
    color: var(--ink);
  }
  :global(html.dark .bento-card.stack-card .bento-card-body-rendered .stack-chip) {
    background: rgba(255, 255, 255, 0.08);
  }
  /* Anchor chips inside the modal — accent-tinted lift. */
  :global(.bento-card.stack-card .bento-card-body-rendered .stack-chip:has(em)) {
    background: var(--accent-soft);
  }

  /* Paper-bg overrides for the cloned modal body (default rules in
     BentoGrid.astro assume the dark project-card cover). */
  :global(.bento-card.stack-card .bento-card-body-rendered) {
    color: var(--ink-dim);
  }
  :global(.bento-card.stack-card .bento-card-body-rendered :is(h2, h3, h4)) {
    color: var(--ink);
  }

  /* Hover-revealed expand affordance + close button repainted for paper. */
  :global(.bento-card.stack-card .cs-expand) {
    background: rgba(26, 26, 28, 0.06);
    color: var(--ink);
    box-shadow: 0 2px 40px rgba(0, 0, 0, 0.10);
  }
  :global(.bento-card.stack-card .cs-expand:hover) {
    background: rgba(26, 26, 28, 0.12);
  }
  :global(.bento-card.stack-card .cs-close) {
    background: rgba(26, 26, 28, 0.06);
    color: var(--ink);
  }
  :global(.bento-card.stack-card .cs-close:hover) {
    background: rgba(26, 26, 28, 0.12);
  }
  :global(html.dark .bento-card.stack-card .cs-expand),
  :global(html.dark .bento-card.stack-card .cs-close) {
    background: rgba(255, 255, 255, 0.08);
  }
  :global(html.dark .bento-card.stack-card .cs-expand:hover),
  :global(html.dark .bento-card.stack-card .cs-close:hover) {
    background: rgba(255, 255, 255, 0.16);
  }
</style>
