---
// Tech-stack marquee card. Static (non-clickable) sibling of BentoCard,
// inheriting the .bento-card base layout from BentoGrid.astro (must be on
// the same page) and overriding for paper background, custom aspect, and
// the marquee container. The runtime at src/scripts/bento-stack.ts
// populates N rows of brand-icon tiles based on available vertical space.
//
// Preserves the #skills-tools anchor (linked from Nav.astro) so existing
// in-page links still resolve after replacing SkillsTools.astro.
---

<article
  id="skills-tools"
  class="bento-card stack-card"
  data-bento-card
  data-slug="stack"
  role="button"
  tabindex="0"
  aria-haspopup="dialog"
  aria-expanded="false"
>
  <div class="card-body">
    <div class="card-eyebrow">04 · Stack</div>
    <div class="card-title">Tools I <em>actually</em> reach for</div>
    <p class="card-text">Languages, ML frameworks, infra.</p>
  </div>
  <div class="marquee" aria-hidden="true" data-bento-stack></div>
  <!-- Cloned into a visible .bento-card-body-rendered on expand. The four
       categorized lists port the content from the removed SkillsTools
       component; first item in each list is emphasized via <em>. -->
  <div class="bento-card-body" hidden>
    <h3>Languages</h3>
    <ul>
      <li><em>Python</em></li>
      <li>C++</li>
      <li>JavaScript</li>
      <li>SQL</li>
      <li>Bash</li>
      <li>Swift</li>
    </ul>
    <h3>ML / AI</h3>
    <ul>
      <li><em>PyTorch</em></li>
      <li>TensorFlow</li>
      <li>TensorRT</li>
      <li>ONNX</li>
      <li>OpenCV</li>
      <li>GStreamer</li>
      <li>Nvidia Jetson</li>
    </ul>
    <h3>Infra &amp; DevOps</h3>
    <ul>
      <li><em>Docker</em></li>
      <li>Jenkins</li>
      <li>GitLab CI/CD</li>
      <li>AWS S3</li>
      <li>Grafana</li>
      <li>ELK</li>
      <li>Kubernetes</li>
    </ul>
    <h3>Frameworks &amp; Tools</h3>
    <ul>
      <li><em>Flask</em></li>
      <li>REST APIs</li>
      <li>PostgreSQL</li>
      <li>Selenium</li>
      <li>Scrapy</li>
      <li>Postman</li>
      <li>Git</li>
    </ul>
  </div>
</article>

<script>
  import '../scripts/bento-stack.ts';
</script>

<style>
  /* Paper bg, default cursor, custom aspect. The .bento-card base sets
     aspect-ratio: 4/1 (banner); we override to 3/1 for a slightly taller
     box that fits 2-3 marquee rows comfortably. */
  :global(.bento-card.stack-card),
  :global(.bento-card.stack-card:hover) {
    background-color: var(--paper);
    cursor: pointer;
    aspect-ratio: 3 / 1;
  }
  @media (max-width: 540px) {
    :global(.bento-card.stack-card),
    :global(.bento-card.stack-card:hover) {
      aspect-ratio: 5 / 3;
    }
  }

  /* Body content pinned top-left. Marquee fills the bottom area absolutely. */
  :global(.bento-card.stack-card .card-body) {
    text-align: left;
    padding-bottom: 0;
  }
  /* Eyebrow visible at rest (project cards hide it for the minimal-mode
     effect; the stack card isn't a case study, eyebrow is part of the
     section header). */
  :global(.bento-card.stack-card .card-eyebrow) {
    opacity: 1;
    color: var(--ink-3);
  }
  /* Title sits at its natural position — no rest-y translate (the stack
     card doesn't expand, so the translate machinery doesn't apply). */
  :global(.bento-card.stack-card .card-title) {
    color: var(--ink);
    font-size: clamp(1.5rem, 1vw + 1rem, 1.75rem);
    transform: none;
  }
  :global(.bento-card.stack-card .card-title em) {
    font-style: italic;
    color: var(--accent);
  }
  :global(.bento-card.stack-card .card-text) {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--ink-dim);
    margin-top: 6px;
  }

  /* Marquee container — anchored to card bottom; horizontal edge fade
     via mask so tiles slide in/out gracefully. */
  :global(.bento-card.stack-card .marquee) {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
            mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  :global(.bento-card.stack-card .marquee-row) {
    overflow: hidden;
  }
  :global(.bento-card.stack-card .marquee-track) {
    display: flex;
    gap: 10px;
    /* flex gap only applies between items, not after the last one. Without
       a trailing gap, translateX(-50%) lands 1 gap short of the seamless
       loop point — visible as a brief blank when the animation cycles. */
    padding-right: 10px;
    width: max-content;
    animation: bento-stack-marquee 38s linear infinite;
  }
  /* Alternate-direction rows: every other row scrolls the opposite way. */
  :global(.bento-card.stack-card .marquee-row.reverse .marquee-track) {
    animation-direction: reverse;
  }
  @keyframes bento-stack-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  :global(.bento-card.stack-card .stack-tile) {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 11px;
    background: var(--bg-color, #333);
    display: grid;
    place-items: center;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 4px 10px -6px rgba(0, 0, 0, 0.4);
  }
  :global(.bento-card.stack-card .stack-tile img) {
    width: 56%;
    height: 56%;
    object-fit: contain;
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.bento-card.stack-card .marquee-track) {
      animation: none;
    }
  }

  /* ── Expand-on-click lifecycle overrides ────────────────────── */
  /* Marquee opacity through the lifecycle:
     - is-expanding / is-expanded: hidden (cloned body content takes over).
     - is-collapsing: 1 (fades back in immediately on close start so it's
       at full opacity ~300ms before the 520ms morph back completes —
       reappears as part of the closing motion rather than snapping in
       after cleanup).
     During close the card has BOTH .is-expanding and .is-collapsing;
     same-specificity rules → source order wins → opacity:1 takes effect. */
  :global(.bento-card.stack-card .marquee) {
    transition: opacity 220ms ease;
  }
  :global(.bento-card.stack-card.is-expanding .marquee),
  :global(.bento-card.stack-card.is-expanded .marquee) {
    opacity: 0;
  }
  :global(.bento-card.stack-card.is-collapsing .marquee) {
    opacity: 1;
  }

  /* Paper-bg overrides for the cloned modal body (default rules in
     BentoGrid.astro assume the dark project-card cover, with cream text). */
  :global(.bento-card.stack-card .bento-card-body-rendered) {
    color: var(--ink-dim);
  }
  :global(.bento-card.stack-card .bento-card-body-rendered :is(h2, h3)) {
    color: var(--ink);
  }
  :global(.bento-card.stack-card .bento-card-body-rendered code) {
    background: rgba(26, 26, 28, 0.06);
  }
  :global(.bento-card.stack-card .bento-card-body-rendered em) {
    font-style: italic;
    color: var(--accent);
  }

  /* Hover-revealed expand affordance + close button repainted for paper. */
  :global(.bento-card.stack-card .cs-expand) {
    background: rgba(26, 26, 28, 0.06);
    color: var(--ink);
    box-shadow: 0 2px 40px rgba(0, 0, 0, 0.10);
  }
  :global(.bento-card.stack-card .cs-expand:hover) {
    background: rgba(26, 26, 28, 0.12);
  }
  :global(.bento-card.stack-card .cs-close) {
    background: rgba(26, 26, 28, 0.06);
    color: var(--ink);
  }
  :global(.bento-card.stack-card .cs-close:hover) {
    background: rgba(26, 26, 28, 0.12);
  }
</style>
