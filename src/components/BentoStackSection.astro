---
// Tech-stack section. Renders an h2 section title followed by one labelled
// row of logo pills per category. Preserves `#skills-tools` for Nav.astro /
// MobileMenu.astro. Each tool is a reusable <TechPill> (brand logo on a light
// plate + name); the stack data lives in src/data/techStack.ts.
import { techGroups } from '../data/techStack';
import TechPill from './TechPill.astro';
---

<section id="skills-tools" class="stack-section" data-nav-section="skills-tools">
  <h2 class="section-title">Tools I <em>actually</em> reach for.</h2>

  <div class="stack-groups">
    {
      techGroups.map((group) => (
        <div class="stack-group">
          <h3 class="stack-group-label">{group.label}</h3>
          <ul class="stack-pill-row">
            {group.items.map((item) => (
              <TechPill {...item} />
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  .section-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 1.5vw + 1.25rem, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 32px;
  }

  .stack-groups {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .stack-group-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-dim);
    margin: 0 0 12px;
  }

  .stack-pill-row {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
</style>
