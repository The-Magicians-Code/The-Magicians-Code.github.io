---
// Tech-stack section. Header ("Tools I *actually* reach for") sits as a
// separator above two independent bento cards, mirroring the structure
// of BentoProjectsSection.astro. Each sub-card has its own pretext
// title, its own expand-to-modal lifecycle, and its own categorized
// chip rows in the modal body.
//
// Cards:
//   • "Languages I think in" — Languages + ML / AI chip rows
//   • "Tools I reach for"    — Infra & DevOps + Frameworks & Tools
//
// `data-no-mode-toggle` on each card skips the TL;DR ↔ Detailed pill
// (single content mode). The `id="skills-tools"` anchor lives only on
// the outer section; duplicating it on the sub-cards would silently
// break the nav anchor (Nav.astro:21, MobileMenu.astro:8).
//
// Behavior caveat (codex-flagged): bento-expand's openState is a
// page-level singleton. Two stack cards cannot be open simultaneously.
// Clicking card B while card A is open: the backdrop click dismisses
// A; a second click on B opens it. Auto-swap is intentionally out of
// scope for this change.
---

<section id="skills-tools" class="stack-section">
  <h2 class="section-title">Tools I <em>actually</em> reach for</h2>

  <div class="stack-sub-grid">
    <article
      class="bento-card stack-card"
      data-bento-card
      data-slug="stack-languages"
      data-no-mode-toggle
      role="button"
      tabindex="0"
      aria-haspopup="dialog"
      aria-expanded="false"
      aria-label="Languages I think in"
    >
      <span class="cs-expand" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 3 21 3 21 9" />
          <polyline points="9 21 3 21 3 15" />
          <line x1="21" y1="3" x2="14" y2="10" />
          <line x1="3" y1="21" x2="10" y2="14" />
        </svg>
      </span>
      <div class="card-body">
        <div class="card-title">Languages I <em>think in</em></div>
      </div>
      <div class="bento-card-body" hidden>
        <h4>Languages</h4>
        <ul class="stack-chip-row">
          <li class="stack-chip"><em>Python</em></li>
          <li class="stack-chip">C++</li>
          <li class="stack-chip">JavaScript</li>
          <li class="stack-chip">SQL</li>
          <li class="stack-chip">Bash</li>
          <li class="stack-chip">Swift</li>
        </ul>
        <h4>ML / AI</h4>
        <ul class="stack-chip-row">
          <li class="stack-chip"><em>PyTorch</em></li>
          <li class="stack-chip">TensorFlow</li>
          <li class="stack-chip">TensorRT</li>
          <li class="stack-chip">ONNX</li>
          <li class="stack-chip">OpenCV</li>
          <li class="stack-chip">GStreamer</li>
          <li class="stack-chip">Nvidia Jetson</li>
        </ul>
      </div>
    </article>

    <article
      class="bento-card stack-card"
      data-bento-card
      data-slug="stack-tools"
      data-no-mode-toggle
      role="button"
      tabindex="0"
      aria-haspopup="dialog"
      aria-expanded="false"
      aria-label="Tools I reach for"
    >
      <span class="cs-expand" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 3 21 3 21 9" />
          <polyline points="9 21 3 21 3 15" />
          <line x1="21" y1="3" x2="14" y2="10" />
          <line x1="3" y1="21" x2="10" y2="14" />
        </svg>
      </span>
      <div class="card-body">
        <div class="card-title">Tools I <em>reach for</em></div>
      </div>
      <div class="bento-card-body" hidden>
        <h4>Infra &amp; DevOps</h4>
        <ul class="stack-chip-row">
          <li class="stack-chip"><em>Docker</em></li>
          <li class="stack-chip">Jenkins</li>
          <li class="stack-chip">GitLab CI/CD</li>
          <li class="stack-chip">AWS S3</li>
          <li class="stack-chip">Grafana</li>
          <li class="stack-chip">ELK</li>
          <li class="stack-chip">Kubernetes</li>
        </ul>
        <h4>Frameworks &amp; Tools</h4>
        <ul class="stack-chip-row">
          <li class="stack-chip"><em>Flask</em></li>
          <li class="stack-chip">REST APIs</li>
          <li class="stack-chip">PostgreSQL</li>
          <li class="stack-chip">Selenium</li>
          <li class="stack-chip">Scrapy</li>
          <li class="stack-chip">Postman</li>
          <li class="stack-chip">Git</li>
        </ul>
      </div>
    </article>
  </div>
</section>

<script>
  // Two sub-cards on the page need the bento-expand machinery wired up.
  // BentoGrid.astro imports it for the projects section; importing here
  // too is safe (the script self-guards against double-init).
  import '../scripts/bento-expand.ts';
</script>

<style>
  /* Header styled to match BentoProjectsSection.astro section-title. */
  .section-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 1.5vw + 1.25rem, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 24px;
  }

  .stack-sub-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  @media (max-width: 640px) {
    .stack-sub-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Paper background, square-ish aspect for the 2-col layout.
     Overrides BentoGrid.astro's 4:1 base aspect-ratio. */
  :global(.bento-card.stack-card),
  :global(.bento-card.stack-card:hover) {
    background-color: var(--paper);
    cursor: pointer;
    aspect-ratio: 5 / 4;
  }
  @media (max-width: 640px) {
    :global(.bento-card.stack-card),
    :global(.bento-card.stack-card:hover) {
      aspect-ratio: 5 / 3;
    }
  }

  /* card-body inherits BentoGrid's flex column + justify-content:
     flex-start. The title is then visually pushed to the body's
     vertical center via --title-rest-y (computed in bento-expand.ts
     syncTitleRestY) — same machinery as project cards. */

  /* Expanded modal body — chip rows under category subheadings. */
  :global(.bento-card.stack-card .bento-card-body-rendered h4) {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-dim);
    margin: 18px 0 10px;
  }
  :global(.bento-card.stack-card .bento-card-body-rendered h4:first-of-type) {
    margin-top: 0;
  }
  :global(.bento-card.stack-card .bento-card-body-rendered .stack-chip-row) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  :global(.bento-card.stack-card .bento-card-body-rendered .stack-chip) {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(26, 26, 28, 0.06);
    color: var(--ink);
  }
  :global(html.dark .bento-card.stack-card .bento-card-body-rendered .stack-chip) {
    background: rgba(255, 255, 255, 0.08);
  }
  /* Anchor chips — accent-tinted lift. */
  :global(.bento-card.stack-card .bento-card-body-rendered .stack-chip:has(em)) {
    background: var(--accent-soft);
  }

  /* Paper-bg overrides for the cloned modal body. */
  :global(.bento-card.stack-card .bento-card-body-rendered) {
    color: var(--ink-dim);
  }
  :global(.bento-card.stack-card .bento-card-body-rendered :is(h2, h3, h4)) {
    color: var(--ink);
  }

  /* Hover-revealed expand affordance + close button repainted for paper. */
  :global(.bento-card.stack-card .cs-expand) {
    background: rgba(26, 26, 28, 0.06);
    color: var(--ink);
    box-shadow: 0 2px 40px rgba(0, 0, 0, 0.10);
  }
  :global(.bento-card.stack-card .cs-expand:hover) {
    background: rgba(26, 26, 28, 0.12);
  }
  :global(.bento-card.stack-card .cs-close) {
    background: rgba(26, 26, 28, 0.06);
    color: var(--ink);
  }
  :global(.bento-card.stack-card .cs-close:hover) {
    background: rgba(26, 26, 28, 0.12);
  }
  :global(html.dark .bento-card.stack-card .cs-expand),
  :global(html.dark .bento-card.stack-card .cs-close) {
    background: rgba(255, 255, 255, 0.08);
  }
  :global(html.dark .bento-card.stack-card .cs-expand:hover),
  :global(html.dark .bento-card.stack-card .cs-close:hover) {
    background: rgba(255, 255, 255, 0.16);
  }
</style>
