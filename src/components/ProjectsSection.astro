---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="projects" class="section-fade-in" style="--delay: 0.2s">
  <div class="section-eyebrow">03 · Selected work</div>
  <h2 class="section-title">Projects <em>worth</em> showing.</h2>
  <div class="projects-grid">
    {projects.map((project) => (
      <ProjectCard
        title={project.data.title}
        description={project.data.description}
        repoUrl={project.data.repoUrl}
        slug={project.id}
      />
    ))}
    <a
      href="https://github.com/The-Magicians-Code/"
      target="_blank"
      rel="noopener noreferrer"
      class="card all-projects"
      aria-label="View all projects on GitHub"
    >
      <Icon name="lucide:github" class="w-5 h-5" aria-hidden="true" />
      <span>See all projects on GitHub</span>
      <Icon name="lucide:arrow-up-right" class="w-4 h-4 trail" aria-hidden="true" />
    </a>
  </div>
</section>

<style>
  .section-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 1.5vw + 1.25rem, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 24px;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 720px) {
    .projects-grid { grid-template-columns: 1fr 1fr; }
  }

  .all-projects {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color 0.2s ease, transform 220ms var(--ease), box-shadow 220ms var(--ease);
  }
  .all-projects:hover {
    color: var(--ink);
  }
  .all-projects .trail {
    transition: transform 0.2s ease;
  }
  .all-projects:hover .trail {
    transform: translate(2px, -2px);
  }
</style>
